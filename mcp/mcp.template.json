{
  "mcpServers": {
    "sentry": {
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server@latest"],
      "env": {
        "SENTRY_ACCESS_TOKEN": "${SENTRY_ACCESS_TOKEN}"
      }
    },
    "logzio": {
      "command": "npx",
      "args": ["-y", "logzio-mcp-server"],
      "env": {
        "LOGZIO_API_KEY": "${LOGZIO_API_KEY}",
        "LOGZIO_REGION": "${LOGZIO_REGION}"
      }
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    },
    "coda": {
      "command": "npx",
      "args": ["-y", "coda-mcp-readonly"],
      "env": {
        "API_KEY": "${CODA_API_KEY}"
      }
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "shortcut": {
      "type": "http",
      "url": "https://mcp.shortcut.com/mcp",
      "headers": {
        "Authorization": "Bearer ${SHORTCUT_API_TOKEN}"
      }
    },
    "clickhouse-docs": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://clickhouse.mcp.kapa.ai/"]
    }
  }
}
