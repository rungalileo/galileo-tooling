# Galileo Tooling — Environment Variables
# Copy this file to .env and fill in your tokens.
# Never commit .env to git.

# Sentry (https://sentry.io/settings/account/api/auth-tokens/)
# SENTRY_ACCESS_TOKEN=

# Logz.io (get from 1Password — ask Shuai Shao for access)
# LOGZIO_API_KEY=
# LOGZIO_REGION=us

# Slack (see mcp/slack.md for setup instructions)
# SLACK_BOT_TOKEN=
# SLACK_TEAM_ID=

# ClickHouse
# CLICKHOUSE_HOST=
# CLICKHOUSE_USER=
# CLICKHOUSE_PASSWORD=

# Shortcut
# SHORTCUT_API_TOKEN=
