# Galileo Skills — Environment Variables
# Copy this file to .env and fill in your tokens.
# Never commit .env to git.

# Sentry
# SENTRY_AUTH_TOKEN=

# Shortcut
# SHORTCUT_API_TOKEN=

# Logz.io
# LOGZIO_API_TOKEN=
# LOGZIO_ACCOUNT_REGION=

# ClickHouse
# CLICKHOUSE_HOST=
# CLICKHOUSE_USER=
# CLICKHOUSE_PASSWORD=
